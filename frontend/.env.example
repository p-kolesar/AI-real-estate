# Base URL the app calls for the backend API. Leave UNSET to run on stub/demo
# data (no backend needed).
#
# In production the deploy-frontend workflow sets this at build time to the
# Function App's full URL (cross-origin; the backend's CORS allows the Static
# Web App origin), e.g.:
# VITE_API_BASE=https://<func-host>/api

# Dev-only: proxy /api to a real backend during `npm run dev` (avoids CORS).
# Point at the deployed Function App or a local `func start`.
# VITE_API_PROXY=http://localhost:7071
